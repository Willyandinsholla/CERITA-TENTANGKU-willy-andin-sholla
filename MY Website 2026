<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Vision 2026 | Future Ecosystem</title>
    
    <style>
        /* --- RESET & VARIABLES --- */
        :root {
            --bg-color: #05070a;
            --primary-accent: #00d2ff;
            --secondary-accent: #3a7bd5;
            --glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.1);
            --text-main: #e0e0e0;
            --text-dim: #94a3b8;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* --- BACKGROUND CANVAS --- */
        #canvas-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            background: radial-gradient(circle at center, #0a1018 0%, #05070a 100%);
        }

        /* --- LAYOUT --- */
        .wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 80px 20px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .hero {
            text-align: center;
            margin-bottom: 80px;
            opacity: 0;
            transform: translateY(30px);
            transition: all 1s ease;
        }

        .hero.active {
            opacity: 1;
            transform: translateY(0);
        }

        .hero h1 {
            font-size: clamp(2.5rem, 6vw, 4rem);
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 20px;
            background: linear-gradient(135deg, #fff 30%, var(--primary-accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-dim);
            max-width: 700px;
            margin: 0 auto;
        }

        /* --- CARDS SECTION --- */
        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            width: 100%;
        }

        .card {
            background: var(--glass);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid var(--border-glass);
            border-radius: 30px;
            padding: 50px;
            position: relative;
            transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
            opacity: 0;
            transform: translateY(50px);
        }

        .card.active {
            opacity: 1;
            transform: translateY(0);
        }

        .card:hover {
            background: rgba(255, 255, 255, 0.06);
            border-color: var(--primary-accent);
            box-shadow: 0 25px 50px -12px rgba(0, 210, 255, 0.2);
            transform: scale(1.02);
        }

        .card-tag {
            display: inline-block;
            padding: 6px 14px;
            background: rgba(0, 210, 255, 0.1);
            color: var(--primary-accent);
            border-radius: 100px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 20px;
        }

        .card h2 {
            font-size: 2rem;
            margin-bottom: 20px;
            color: #fff;
        }

        .card p {
            line-height: 1.7;
            color: var(--text-dim);
            font-size: 1.1rem;
        }

        /* --- LIST STYLING --- */
        .mission-list {
            margin-top: 25px;
            list-style: none;
        }

        .mission-item {
            display: flex;
            align-items: flex-start;
            margin-bottom: 20px;
            gap: 15px;
        }

        .icon-circle {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, var(--primary-accent), var(--secondary-accent));
            border-radius: 50%;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: bold;
            color: #000;
        }

        /* --- FOOTER CTA --- */
        .cta-section {
            margin-top: 100px;
            text-align: center;
            opacity: 0;
            transition: all 1s ease;
        }

        .cta-section.active { opacity: 1; }

        .btn {
            padding: 16px 35px;
            background: #fff;
            color: #000;
            text-decoration: none;
            border-radius: 100px;
            font-weight: 700;
            transition: 0.3s;
            display: inline-block;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(255, 255, 255, 0.2);
        }

        @media (max-width: 768px) {
            .grid-container { grid-template-columns: 1fr; }
            .card { padding: 30px; }
        }
    </style>
</head>
<body>

    <canvas id="canvas-bg"></canvas>

    <div class="wrapper">
        <header class="hero reveal">
            <div class="card-tag">Tahun Fiskal 2026</div>
            <h1>SELAMAT DATANG DI ACARA JOAN <br>INI AUREL.</h1>
            <p>KAMI MEMBANGUN DUNIA BARU UNTUK MASA DEPAN CEMERLANG</p>
        </header>

        <div class="grid-container">
            <div class="card reveal">
                <div class="card-tag">Core Goal</div>
                <h2>Visi Kami</h2>
                <p>Menjadi pionir dalam ekosistem digital otonom yang memprioritaskan etika AI, memastikan bahwa setiap baris kode yang kami tulis berkontribusi pada kemajuan sosial dan kelestarian planet bumi.</p>
            </div>

            <div class="card reveal">
                <div class="card-tag">Strategic Path</div>
                <h2>Misi Kami</h2>
                <div class="mission-list">
                    <div class="mission-item">
                        <div class="icon-circle">1</div>
                        <p><strong>Human-Centric AI:</strong> Mengembangkan solusi otomasi yang meningkatkan kreativitas manusia, bukan menggantikannya.</p>
                    </div>
                    <div class="mission-item">
                        <div class="icon-circle">2</div>
                        <p><strong>Net Zero Digital:</strong> Mencapai operasional bebas karbon melalui optimalisasi algoritma hemat energi.</p>
                    </div>
                    <div class="mission-item">
                        <div class="icon-circle">3</div>
                        <p><strong>Data Sovereignty:</strong> Memberikan kendali penuh data kepada pengguna melalui infrastruktur Web3 dan enkripsi kuantum.</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="cta-section reveal">
            <a href="#" class="btn">Bergabung Menuju Masa Depan</a>
        </div>
    </div>

    <script>
        /* --- ANIMATED BACKGROUND (CANVAS) --- */
        const canvas = document.getElementById('canvas-bg');
        const ctx = canvas.getContext('2d');
        let particles = [];

        function initCanvas() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.size = Math.random() * 1.5 + 0.5;
                this.speedX = Math.random() * 0.5 - 0.25;
                this.speedY = Math.random() * 0.5 - 0.25;
                this.opacity = Math.random() * 0.5 + 0.2;
            }
            update() {
                this.x += this.speedX;
                this.y += this.speedY;
                if (this.x > canvas.width) this.x = 0;
                if (this.x < 0) this.x = canvas.width;
                if (this.y > canvas.height) this.y = 0;
                if (this.y < 0) this.y = canvas.height;
            }
            draw() {
                ctx.fillStyle = `rgba(0, 210, 255, ${this.opacity})`;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function createParticles() {
            particles = [];
            const count = (canvas.width * canvas.height) / 15000;
            for (let i = 0; i < count; i++) {
                particles.push(new Particle());
            }
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            requestAnimationFrame(animate);
        }

        /* --- SCROLL REVEAL LOGIC --- */
        function handleReveal() {
            const reveals = document.querySelectorAll('.reveal');
            reveals.forEach(el => {
                const rect = el.getBoundingClientRect();
                if (rect.top < window.innerHeight - 100) {
                    el.classList.add('active');
                }
            });
        }

        window.addEventListener('resize', () => {
            initCanvas();
            createParticles();
        });

        window.addEventListener('scroll', handleReveal);
        
        // Start Everything
        initCanvas();
        createParticles();
        animate();
        setTimeout(handleReveal, 200);
    </script>
</body>
</html>
